DATABASE_URL=postgres://moviey:password@localhost:5433/moviey
UPLOAD_DIR=./uploads
OUTPUT_DIR=./stream_output

# JWT Secret (use a strong random key)  
SECRET_KEY=secure_random_key_for_jwt_signing  

# Server  
HOST=0.0.0.0  
PORT=3000  

# Logging  
LOG_LEVEL=info  
RUST_LOG=info  

# Video Processing  
MAX_UPLOAD_SIZE=5GB  
ALLOWED_VIDEO_FORMATS=mp4,mkv,avi  

# Batch Job Configuration
BATCH_JOB_ENABLED=true
BATCH_JOB_TIMEZONE=UTC
EMBEDDING_BATCH_SIZE=100
SIMILARITY_BATCH_SIZE=50
CACHE_WARMING_BATCH_SIZE=100

# Job Timeouts (in seconds)
USER_EMBEDDING_TIMEOUT=3600
MOVIE_SIMILARITY_TIMEOUT=1800
CACHE_WARMING_TIMEOUT=3600
DATA_QUALITY_TIMEOUT=1800
